    "angular-eslint": "^20.3.0",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "~13.2.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
