{
  "name": "medcontrol",
  "version": "0.0.0",
  "private": true,
  "description": "MedControl — Monorepo (backend .NET 10 + web Angular + mobile React Native)",
  "scripts": {
    "dev": "nx run-many --target=serve --all --parallel=3",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "type-check": "nx run-many --target=type-check --all",
    "affected:build": "nx affected --target=build",
    "affected:test": "nx affected --target=test",
    "affected:lint": "nx affected --target=lint",
    "prepare": "husky"
  },
  "devDependencies": {
    "@angular-devkit/core": "~20.3.0",
    "@angular-devkit/schematics": "~20.3.0",
    "@angular/build": "~20.3.0",
    "@angular/cli": "~20.3.0",
    "@angular/compiler-cli": "~20.3.0",
    "@angular/language-service": "~20.3.0",
    "@babel/runtime": "~7.27.6",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^9.8.0",
    "@nx/angular": "^21.0.0",
    "@nx/eslint": "21.6.10",
    "@nx/eslint-plugin": "21.6.10",
    "@nx/expo": "21.6.10",
    "@nx/jest": "21.6.10",
    "@nx/js": "21.6.10",
    "@nx/web": "21.6.10",
    "@schematics/angular": "~20.3.0",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/jest": "^29.5.12",
    "@types/node": "18.16.9",
    "@typescript-eslint/utils": "^8.40.0",
    "angular-eslint": "^20.3.0",
    "babel-jest": "^29.7.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-preset-angular": "~14.6.1",
    "jest-util": "^29.7.0",
    "nx": "^21.0.0",
    "prettier": "^2.6.2",
    "semantic-release": "^24.0.0",
    "sharp": "^0.34.5",
    "ts-jest": "^29.1.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.40.0"
  },
  "pnpm": {
    "overrides": {
      "react-native-worklets": "0.7.4"
    }
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "dependencies": {
    "@angular/animations": "~20.3.18",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "~20.3.0",
    "@angular/compiler": "~20.3.0",
    "@angular/core": "~20.3.0",
    "@angular/forms": "~20.3.0",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "~20.3.0",
    "@angular/platform-browser-dynamic": "~20.3.0",
    "@angular/router": "~20.3.0",
    "rxjs": "~7.8.0",
    "zone.js": "~0.15.0"
  }
}
