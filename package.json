{
  "name": "medcontrol",
  "version": "0.0.0",
  "private": true,
  "description": "MedControl — Monorepo (backend .NET 10 + web Angular + mobile React Native)",
  "scripts": {
    "dev": "nx run-many --target=serve --all --parallel=3",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "type-check": "nx run-many --target=type-check --all",
    "affected:build": "nx affected --target=build",
    "affected:test": "nx affected --target=test",
    "affected:lint": "nx affected --target=lint",
    "prepare": "husky"
  },
  "devDependencies": {
    "@angular-devkit/core": "~20.3.0",
