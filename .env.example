# =============================================
# MedControl — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env real
# =============================================

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/medcontrol?sslmode=require

# --- JWT ---
JWT_SECRET=sua-chave-secreta-com-minimo-256-bits-gere-com-openssl-rand-base64-64
JWT_ISSUER=https://medcontrol.app
JWT_AUDIENCE=medcontrol-api
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=30

# --- Google OAuth ---
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@medcontrol.app

# --- Cache (Upstash Redis) ---
UPSTASH_REDIS_URL=rediss://default:xxxx@xxx.upstash.io:6380
UPSTASH_REDIS_TOKEN=xxxx

# --- Storage (Cloudflare R2) ---
R2_ACCOUNT_ID=xxxx
R2_ACCESS_KEY_ID=xxxx
R2_SECRET_ACCESS_KEY=xxxx
R2_BUCKET_NAME=medcontrol-uploads
R2_PUBLIC_URL=https://uploads.medcontrol.app

# --- App ---
APP_ENV=development
API_BASE_URL=http://localhost:5000
WEB_BASE_URL=http://localhost:4200

# --- Sentry (monitoring) ---
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
